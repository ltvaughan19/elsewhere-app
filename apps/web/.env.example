# Public application origin used for redirects, sitemap URLs, and absolute links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# One Supabase project for marketing, the planning app, and editorial admin.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy fallback; leave blank when using a publishable key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Prefer a modern secret key; the service-role key is a legacy fallback.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel sends this bearer secret to the daily official-source monitor.
# Generate a dedicated high-entropy value; never prefix it with NEXT_PUBLIC_.
CRON_SECRET=

# Narrow, expiring JWT whose role claim is exactly `source_monitor_worker`.
# It may claim and complete monitor jobs only; never use a service-role key here.
SUPABASE_SOURCE_MONITOR_WORKER_JWT=
# Optional integer from 1 through 10. Defaults to 5.
SOURCE_MONITOR_BATCH_SIZE=5

# Corridor Brief email delivery.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Elsewhere <hello@elsewhereplan.com>
RESEND_AUDIENCE_ID=
NEWSLETTER_WEBHOOK=
WAITLIST_WEBHOOK=

# Optional product analytics.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
